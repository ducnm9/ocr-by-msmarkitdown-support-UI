# Upload configuration
UPLOAD_MAX_SIZE_MB=50
UPLOAD_DIR=/tmp/markitdown_uploads

# ExifTool path (optional, leave empty to use system default)
EXIFTOOL_PATH=

# Local LLM endpoints (Docker: use host.docker.internal to reach host machine)
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# LLM Provider API Keys (fill in as needed)
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
GOOGLE_API_KEY=
TOGETHER_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
